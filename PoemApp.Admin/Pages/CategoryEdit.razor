@page "/categories/edit/{Id:int}"
@attribute [Authorize]
@using PoemApp.Admin.Services
@using PoemApp.Core.DTOs
@using PoemApp.Core.Enums
@using PoemApp.Core.Extensions
@inject CategoriesApiClient CategoriesClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudPaper Class="pa-4 mx-auto" Style="max-width:800px">
    <MudText Typo="Typo.h5">롸잚긍서</MudText>

    <EditForm Model="_model" OnValidSubmit="HandleValid">
        <MudSelect T="CategoryTypeEnum" Label="잚謹" @bind-Value="_model.Type" Required="true">
            @foreach (CategoryTypeEnum t in Enum.GetValues(typeof(CategoryTypeEnum)))
            {
                <MudSelectItem T="CategoryTypeEnum" Value="@t">@t.GetDisplayName()</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_model.Description" Label="췄甘" />

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled">괏닸</MudButton>
        <MudButton Variant="Variant.Text" OnClick="Cancel">혤句</MudButton>
    </EditForm>
</MudPaper>

@code {
    [Parameter] public int Id { get; set; }

    private CreateCategoryDto _model = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id != 0)
        {
            var dto = await CategoriesClient.GetByIdAsync(Id);
            if (dto != null)
            {
                _model = new CreateCategoryDto { Type = dto.Type, Description = dto.Description };
            }
        }
    }

    private async Task HandleValid()
    {
        // Debug: log that handler executed
        await JS.InvokeVoidAsync("console.log", $"HandleValid called. Id={Id}, Type={_model.Type}, Desc={_model.Description}");
        Snackbar.Add($"硫구괏닸롸잚(Id={Id})...", Severity.Info);

        try
        {
            if (Id == 0)
            {
                var res = await CategoriesClient.CreateAsync(_model);
                await JS.InvokeVoidAsync("console.log", $"CreateAsync returned: {res != null}");
                if (res != null)
                {
                    Snackbar.Add("눼쉔냥묘", Severity.Success);
                    Navigation.NavigateTo("/categories");
                }
                else
                {
                    Snackbar.Add("눼쉔呵겨", Severity.Error);
                }
            }
            else
            {
                var ok = await CategoriesClient.UpdateAsync(Id, new UpdateCategoryDto { Type = _model.Type, Description = _model.Description });
                await JS.InvokeVoidAsync("console.log", $"UpdateAsync returned: {ok}");
                if (ok)
                {
                    Snackbar.Add("뫘劤냥묘", Severity.Success);
                    Navigation.NavigateTo("/categories");
                }
                else
                {
                    Snackbar.Add("뫘劤呵겨", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("괏닸呵겨: " + ex.Message, Severity.Error);
            await JS.InvokeVoidAsync("console.error", ex.Message);
        }
    }

    private void Cancel() => Navigation.NavigateTo("/categories");
}
