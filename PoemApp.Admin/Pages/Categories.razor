@page "/categories"
@using PoemApp.Admin.Services
@using PoemApp.Core.DTOs
@using PoemApp.Core.Extensions
@inject CategoriesApiClient CategoriesClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">ЗжРрЙмРэ</MudText>
    <MudDivider Class="my-2" />

    <MudTable Items="_categories" Striped="true" Hover="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="ЫбЫїЗжРр" Adornment="Adornment.Start" AdornmentIcon="Icons.Material.Filled.Search" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreate">аТНЈЗжРр</MudButton>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>РраЭ</MudTh>
            <MudTh>УћГЦ</MudTh>
            <MudTh>УшЪі</MudTh>
            <MudTh></MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd>@context.Type.GetDisplayName()</MudTd>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Description</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="() => Edit(context.Id)">БрМ­</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="() => ConfirmDelete(context.Id)">ЩОГ§</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private List<CategoryDto> _categories = new();
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _categories = await CategoriesClient.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("МгдиЗжРрЪЇАм: " + ex.Message, Severity.Error);
        }
    }

    private void OpenCreate()
    {
        Navigation.NavigateTo("/categories/edit/0");
    }

    private void Edit(int id)
    {
        Navigation.NavigateTo($"/categories/edit/{id}");
    }

    private async Task ConfirmDelete(int id)
    {
        try
        {
            // Use MudBlazor built-in message box to avoid dialog instance issues
            var confirmed = await DialogService.ShowMessageBox(
                "ЩОГ§ШЗШЯ",
                $"ШЗЖЈЩОГ§ЗжРр {id} Т№ЃП",
                yesText: "ШЗЖЈ",
                noText: "ШЁЯћ",
                options: new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small }
            );

            if (confirmed == true)
            {
                await DoDelete(id);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("ЩОГ§ЪЇАм: " + ex.Message, Severity.Error);
        }
    }

    private async Task DoDelete(int id)
    {
        try
        {
            // debug notifications
            Snackbar.Add($"ПЊЪМЩОГ§ЗжРр {id}...", Severity.Info);
            await JS.InvokeVoidAsync("console.log", $"DoDelete called for {id}");

            var ok = await CategoriesClient.DeleteAsync(id);

            await JS.InvokeVoidAsync("console.log", $"Delete response ok={ok}");

            if (ok)
            {
                Snackbar.Add("ЩОГ§ГЩЙІ", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add("ЩОГ§ЪЇАм", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("ЩОГ§ЪЇАм: " + ex.Message, Severity.Error);
            await JS.InvokeVoidAsync("console.error", ex.Message);
        }
    }

    // simple js confirm
    private async Task<bool> JsConfirm(string message)
    {
        return await JS.InvokeAsync<bool>("confirm", message);
    }
}
