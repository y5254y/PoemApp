@page "/categories"
@attribute [Authorize]
@using MudBlazor
@using PoemApp.Core.DTOs
@inject IDialogService DialogService

<PageTitle>目录管理 - PoemApp 管理后台</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">目录管理</MudText>

<MudCard>
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6">目录列表</MudText>
            </MudItem>
            <MudItem xs="12" md="6" Class="text-end">
                <MudButton T="string" Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="Icons.Material.Filled.Add"
                           OnClick="AddCategory">
                    添加目录
                </MudButton>
            </MudItem>
        </MudGrid>

        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
            <MudText Class="text-center">正在加载目录列表...</MudText>
        }
        else if (_categories.Any())
        {
            <MudTable T="CategoryDto" Items="@_categories" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>目录名称</MudTh>
                    <MudTh>描述</MudTh>
                    <MudTh>创建时间</MudTh>
                    <MudTh>操作</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="ID">@context.Id</MudTd>
                    <MudTd DataLabel="目录名称">@context.Name</MudTd>
                    <MudTd DataLabel="描述">@context.Description</MudTd>
                    
                    <MudTd DataLabel="操作">
                        <MudIconButton T="string" Icon="Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => EditCategory(context))" />
                        <MudIconButton T="string" Icon="Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(async () => await DeleteCategory(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Class="text-center">暂无目录数据</MudText>
        }
    </MudCardContent>
</MudCard>

@code {
    private List<CategoryDto> _categories = new List<CategoryDto>();
    private bool _isLoading = true;

    [Inject] private IApiService ApiService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        try
        {
            _isLoading = true;
            StateHasChanged(); // 更新UI显示加载状态

            _categories = await ApiService.GetAsync<List<CategoryDto>>("categories") ?? new List<CategoryDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载目录列表失败: {ex.Message}", Severity.Error);
            _categories = new List<CategoryDto>();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged(); // 更新UI隐藏加载状态
        }
    }

    private void AddCategory()
    {
        Snackbar.Add("添加目录功能待实现", Severity.Info);
    }

    private void EditCategory(CategoryDto category)
    {
        Snackbar.Add($"编辑目录: {category.Name}", Severity.Info);
    }

    private async Task DeleteCategory(CategoryDto category)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", $"确定要删除目录 '{category.Name}' 吗？此操作不可恢复。" },
            { "ButtonText", "删除" },
            { "Color", Color.Error }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = DialogService.Show<MudDialog>("确认删除", parameters, options);
        var result = await dialog.Result;

        // 修复：使用 Canceled 而不是 Cancelled
        if (!result.Canceled)
        {
            try
            {
                var success = await ApiService.DeleteAsync($"categories/{category.Id}");
                if (success)
                {
                    Snackbar.Add("目录删除成功", Severity.Success);
                    await LoadCategories();
                }
                else
                {
                    Snackbar.Add("目录删除失败", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"删除目录失败: {ex.Message}", Severity.Error);
            }
        }
    }
}