@page "/categories"
@using PoemApp.Admin.Services
@using PoemApp.Core.DTOs
@using PoemApp.Core.Extensions
@inject CategoriesApiClient CategoriesClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">ЗжРрЙмРэ</MudText>
    <MudDivider Class="my-2" />

    <div class="d-flex mb-2">
        <MudTextField @bind-Value="_search" Placeholder="ЫбЫїЗжРр" Adornment="Adornment.Start" AdornmentIcon="Icons.Material.Filled.Search" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreate">ДДНЈЗжРр</MudButton>
    </div>

    <MudExpansionPanels>
        @foreach (var root in _roots.OrderBy(r => r.Name))
        {
            <CategoryPanelMud Category="root" Children="GetChildren(root.Id)" OnEdit="Edit" OnDelete="ConfirmDelete" GetChildren="GetChildrenDelegate" />
        }
    </MudExpansionPanels>

    <div class="d-flex justify-center mt-3">
        <MudButton Variant="Variant.Outlined" OnClick="PrevPage" Disabled="@(_page<=1)">ЩЯвЛвГ</MudButton>
        <MudText Class="mx-2">Ек @_page вГ / ЙВ @_totalPages вГ</MudText>
        <MudButton Variant="Variant.Outlined" OnClick="NextPage" Disabled="@(_page>=_totalPages)">ЯТвЛвГ</MudButton>
    </div>
</MudPaper>

@code {
    private List<CategoryDto> _categories = new();
    private string _search = string.Empty;

    private List<CategoryDto> _roots = new();

    private int _page = 1;
    private int _pageSize = 20;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadPagedAsync();
    }

    private async Task LoadPagedAsync()
    {
        try
        {
            var res = await CategoriesClient.GetPagedAsync(_page, _pageSize, _search);
            _categories = res.Items;
            _totalPages = (int)Math.Ceiling((double)res.TotalCount / _pageSize);
            BuildRoots();
        }
        catch (Exception ex)
        {
            Snackbar.Add("МгдиЗжРрЪЇАм: " + ex.Message, Severity.Error);
        }
    }

    private void BuildRoots()
    {
        var lookup = _categories.ToDictionary(c => c.Id);
        _roots.Clear();
        foreach (var c in _categories)
        {
            if (c.ParentId.HasValue && lookup.ContainsKey(c.ParentId.Value)) continue;
            _roots.Add(c);
        }
    }

    private List<CategoryDto> GetChildren(int parentId) => _categories.Where(c => c.ParentId == parentId).OrderBy(c => c.Name).ToList();
    private Func<int, List<CategoryDto>> GetChildrenDelegate => id => GetChildren(id);

    private void OpenCreate() => Navigation.NavigateTo("/categories/edit/0");
    private void Edit(int id) => Navigation.NavigateTo($"/categories/edit/{id}");

    private async Task ConfirmDelete(int id)
    {
        var confirmed = await DialogService.ShowMessageBox("ЩОГ§ШЗШЯ", $"ШЗШЯЩОГ§ЗжРр {id} Т№", yesText: "ШЗШЯ", noText: "ШЁЯћ");
        if (confirmed == true) await DoDelete(id);
    }

    private async Task DoDelete(int id)
    {
        var ok = await CategoriesClient.DeleteAsync(id);
        if (ok) { Snackbar.Add("ЩОГ§ГЩЙІ", Severity.Success); await LoadPagedAsync(); }
        else Snackbar.Add("ЩОГ§ЪЇАм", Severity.Error);
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await LoadPagedAsync(); }
    }

    private async Task NextPage()
    {
        if (_page < _totalPages) { _page++; await LoadPagedAsync(); }
    }
}
