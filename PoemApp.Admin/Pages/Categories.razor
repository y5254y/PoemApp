@page "/categories"
@using PoemApp.Admin.Services
@using PoemApp.Core.DTOs
@using PoemApp.Core.Extensions
@inject CategoriesApiClient CategoriesClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">分类管理</MudText>
    <MudDivider Class="my-2" />

    <MudTable Items="_categories" Striped="true" Hover="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="搜索分类" Adornment="Adornment.Start" AdornmentIcon="Icons.Material.Filled.Search" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreate">创建分类</MudButton>
        </ToolBarContent>

        <HeaderContent>
            <MudTh>名称</MudTh>
            <MudTh>分组</MudTh>
            <MudTh>描述</MudTh>
            <MudTh></MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Group</MudTd>
            <MudTd>@context.Description</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="() => Edit(context.Id)">编辑</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="() => ConfirmDelete(context.Id)">删除</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private List<CategoryDto> _categories = new();
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _categories = await CategoriesClient.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("加载分类失败: " + ex.Message, Severity.Error);
        }
    }

    private void OpenCreate()
    {
        Navigation.NavigateTo("/categories/edit/0");
    }

    private void Edit(int id)
    {
        Navigation.NavigateTo($"/categories/edit/{id}");
    }

    private async Task ConfirmDelete(int id)
    {
        try
        {
            var confirmed = await DialogService.ShowMessageBox(
                "删除确认",
                $"确认删除分类 {id} 吗",
                yesText: "确认",
                noText: "取消",
                options: new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small }
            );

            if (confirmed == true)
            {
                await DoDelete(id);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("删除失败: " + ex.Message, Severity.Error);
        }
    }

    private async Task DoDelete(int id)
    {
        try
        {
            Snackbar.Add($"开始删除分类 {id}...", Severity.Info);
            await JS.InvokeVoidAsync("console.log", $"DoDelete called for {id}");

            var ok = await CategoriesClient.DeleteAsync(id);

            await JS.InvokeVoidAsync("console.log", $"Delete response ok={ok}");

            if (ok)
            {
                Snackbar.Add("删除成功", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add("删除失败", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("删除失败: " + ex.Message, Severity.Error);
            await JS.InvokeVoidAsync("console.error", ex.Message);
        }
    }
}
