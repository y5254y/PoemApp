@page "/"
@page "/dashboard"
@attribute [Authorize]
@using MudBlazor
@using PoemApp.Core.DTOs
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IAdminAuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>仪表板 - PoemApp 管理后台</PageTitle>

<!-- 用户信息栏 - 放在顶部 -->
<MudAppBar Elevation="1" Color="Color.Primary">
    <MudToolBar>
        <!-- 左侧：Logo和标题 -->
        <MudIconButton Icon="Icons.Material.Filled.Menu" Color="Color.Inherit" />
        <MudText Typo="Typo.h6" Color="Color.Inherit">PoemApp 管理后台</MudText>
        
        <MudSpacer />
        
        <!-- 右侧：用户信息和退出 -->
        @if (_currentUser != null)
        {
            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled">
                <MudIcon Icon="Icons.Material.Filled.Person" Class="me-2" />
                <MudText Color="Color.Inherit">@_currentUser.Username</MudText>
            </MudChip>
            
            <MudIconButton T="string" 
                         Icon="Icons.Material.Filled.ExitToApp" 
                         Color="Color.Inherit" 
                         OnClick="Logout"
                         Title="退出登录"
                         Class="ms-2" />
        }
    </MudToolBar>
</MudAppBar>

<MudContainer Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">系统概览</MudText>

    <!-- 系统概览卡片 -->
    <MudGrid Spacing="2">
        <MudItem xs="12" md="3">
            <MudCard>
                <MudCardContent Class="text-center">
                    <MudIcon Icon="Icons.Material.Filled.Book" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.h6">诗文总数</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">2</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="3">
            <MudCard>
                <MudCardContent Class="text-center">
                    <MudIcon Icon="Icons.Material.Filled.Person" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                    <MudText Typo="Typo.h6">作者总数</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Secondary">3</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="3">
            <MudCard>
                <MudCardContent Class="text-center">
                    <MudIcon Icon="Icons.Material.Filled.People" Size="Size.Large" Color="Color.Tertiary" Class="mb-2" />
                    <MudText Typo="Typo.h6">用户总数</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Tertiary">1</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="3">
            <MudCard>
                <MudCardContent Class="text-center">
                    <MudIcon Icon="Icons.Material.Filled.AudioFile" Size="Size.Large" Color="Color.Success" Class="mb-2" />
                    <MudText Typo="Typo.h6">音频总数</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Success">0</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- 最近活动和快速操作 -->
    <MudGrid Class="mt-6">
        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader>
                    <MudCardHeaderContent>
                        <MudText Typo="Typo.h6">最近活动</MudText>
                    </MudCardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string">
                        <MudListItem T="string" Text="新用户注册" SecondaryText="刚刚" />
                        <MudListItem T="string" Text="诗文添加" SecondaryText="5分钟前" />
                        <MudListItem T="string" Text="音频上传" SecondaryText="10分钟前" />
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader>
                    <MudCardHeaderContent>
                        <MudText Typo="Typo.h6">快速操作</MudText>
                    </MudCardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudButton T="string" Variant="Variant.Filled" 
                                  Color="Color.Primary" 
                                  StartIcon="Icons.Material.Filled.Add"
                                  OnClick="NavigateToPoems"
                                  FullWidth="true">
                            添加诗文
                        </MudButton>
                        <MudButton T="string" Variant="Variant.Filled" 
                                  Color="Color.Secondary" 
                                  StartIcon="Icons.Material.Filled.PersonAdd"
                                  OnClick="NavigateToAuthors"
                                  FullWidth="true">
                            添加作者
                        </MudButton>
                        <MudButton T="string" Variant="Variant.Filled" 
                                  Color="Color.Tertiary" 
                                  StartIcon="Icons.Material.Filled.AudioFile"
                                  OnClick="NavigateToAudios"
                                  FullWidth="true">
                            管理音频
                        </MudButton>
                        <MudButton T="string" Variant="Variant.Filled" 
                                  Color="Color.Info" 
                                  StartIcon="Icons.Material.Filled.Category"
                                  OnClick="NavigateToCategories"
                                  FullWidth="true">
                            管理目录
                        </MudButton>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private CurrentUserInfo? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserInfo();
    }

    private async Task LoadCurrentUserInfo()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                _currentUser = new CurrentUserInfo
                {
                    Username = user.Identity.Name ?? "用户",
                    Role = user.FindFirst(ClaimTypes.Role)?.Value ?? "User"
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"获取用户信息失败: {ex.Message}", Severity.Error);
        }
    }

    private void NavigateToPoems()
    {
        Navigation.NavigateTo("/poems");
    }

    private void NavigateToAuthors()
    {
        Navigation.NavigateTo("/authors");
    }

    private void NavigateToAudios()
    {
        Navigation.NavigateTo("/audios");
    }

    private void NavigateToCategories()
    {
        Navigation.NavigateTo("/categories");
    }

    private async Task Logout()
    {
        try
        {
            await AuthService.LogoutAsync();
            Snackbar.Add("退出登录成功", Severity.Success);
            Navigation.NavigateTo("/Account/Login", forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"退出登录失败: {ex.Message}", Severity.Error);
        }
    }
}

