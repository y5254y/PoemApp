@page "/poems"
@using PoemApp.Core.DTOs
@inject HttpClient Http
@using MudBlazor

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">家匡밗잿</MudText>

    <MudTable Items="_poems" Hover="true" Bordered="true" Striped="true">
        <HeaderContent>
            <MudTh>Id</MudTh>
            <MudTh>깃痙</MudTh>
            <MudTh>鱗諒</MudTh>
            <MudTh>날덜</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Id">@context.Id</MudTd>
            <MudTd>@context.Title</MudTd>
            <MudTd>@context.AuthorName</MudTd>
            <MudTd>@context.Dynasty</MudTd>
            <MudTd>
                <MudButton Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">긍서</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private List<PoemDto> _poems = new();

    protected override async Task OnInitializedAsync()
    {
        _poems = await Http.GetFromJsonAsync<List<PoemDto>>("api/poems") ?? new();
    }
}